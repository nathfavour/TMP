{
  "name": "tendon-message-protocol",
  "version": "0.1.0",
  "private": true,
  "author": "nathfavour",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "proto:gen": "mkdir -p src/lib/tmp/generated && pbjs -t static-module -w commonjs -o src/lib/tmp/generated/tendon.js proto/tendon.proto && pbts -o src/lib/tmp/generated/tendon.d.ts src/lib/tmp/generated/tendon.js",
    "prebuild": "pnpm run proto:gen"
  },
  "dependencies": {
    "next": "16.2.9",
    "protobufjs": "^8.6.5",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "protobufjs-cli": "^2.5.6",
    "typescript": "^5"
  },
  "license": "MIT"
}
